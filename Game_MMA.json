{
  "name": "MMA Fighter Card Game",
  "menuBackgroundImage": "https://merkier.github.io/MMA-Fighter-TCG/Images/menu-bg.png",
  "deckBuilding": {
    "mainFilters": [
      "type",
      "category",
      "range",
      "timing",
      "actionCost",
      "staminaCost",
      "tags"
    ],
    "formats": [
      {
        "title": "Standard",
        "gameplay": "Classic",
        "customCategories": [
          "Fighter",
          "Action_Pool",
          "Action_Deck",
          "Range_Clinch",
          "Range_Ground"
        ]
      }
    ]
  },
  "gameplay": {
    "Classic": {
      "mulligan": {
        "info": "Optional mulligan: once only. Draw a new hand of 5, then keep.",
        "startingHandSize": 5,
        "drawNewHand": true
      },
      "newTurn": {
        "drawOnStart": false,
        "sharedTurn": true,
        "firstPlayerTokenName": "Priority",
        "drawPerTurn": 0
      },
      "defaultNotes": "Stamina counter = your current Stamina (start 30).\nWhenever you gain PRIORITY:\n• Restore ceil(10% of current Stamina)\n• Draw 1 Technique card\n• Move up to 3 Action cards from Action Deck → Action Pool\n\nAction Pool: spend Action cards to pay Action costs. Spent Action cards go to the bottom of your Action Deck.\nAll triggers/effects are handled manually by players.",
      "tokens": [
        {
          "name": "Priority",
          "image": "https://merkier.github.io/MMA-Fighter-TCG/Images/tokens/priority.png",
          "isUnique": true,
          "leavesAtEndOfTurn": false
        }
      ],
      "countersStartingValues": [
        30
      ],
      "draggableTokens": [
        {
          "id": "Range_Stand",
          "name": "Range: Stand",
          "image": "https://merkier.github.io/MMA-Fighter-TCG/Images/tokens/range-stand.png"
        },
        {
          "id": "Range_Clinch",
          "name": "Range: Clinch",
          "image": "https://merkier.github.io/MMA-Fighter-TCG/Images/tokens/range-clinch.png"
        },
        {
          "id": "Range_Ground",
          "name": "Range: Ground",
          "image": "https://merkier.github.io/MMA-Fighter-TCG/Images/tokens/range-ground.png"
        },
        {
          "id": "Debuff_Blurred",
          "name": "Blurred Vision",
          "image": "https://merkier.github.io/MMA-Fighter-TCG/Images/tokens/debuff-blurred.png"
        }
      ],
      "sections": {
        "customSections": [
          "Fighter",
          "Action_Pool",
          "Action_Deck",
          "Range_Clinch",
          "Range_Ground"
        ],
        "layout": {
          "direction": "column",
          "isSymetricalForOpponents": false,
          "style": {
            "justifyContent": "start"
          },
          "content": [
            {
              "direction": "row",
              "style": {
                "width": "60%"
              },
              "content": [
                {
                  "section": "Fighter"
                },
                {
                  "section": "Range_Clinch"
                },
                {
                  "section": "Range_Ground"
                }
              ]
            },
{
  "direction": "row",
  "style": { "width": "40%" },
  "content": [
    { "section": "Action_Deck" },
    { "section": "Action_Pool" },
    { "section": "Action_Control" }
  ]
}
          ]
        },
        
        "categoriesAlreadyOnBoard": [
          "Fighter",
          "Action deck->Action_Deck"
        ],
        "autoPlayFromHand": {
          "Technique": "Stack",
          "Fighter": "Fighter",
          "Action": "Action_Pool"
        },
        "autoPlayFromStack": {
          "Technique": "Discard"
        },
"sectionsDict": {
  "Stack": {
    "isDefaultSection": true,
    "title": "Exchange",
    "isHidden": "no",
    "height": "HUGE",
    "alignment": "NONE",
    "isHorizontalAllowed": false,
    "isGroupForbidden": true,
    "displayedTitle": "Exchange"
  },

