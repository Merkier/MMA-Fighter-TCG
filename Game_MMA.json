    "displayedTitle": "Action Deck"
  },

  "Action_Pool": {
    "title": "Action_Pool",
    "isHidden": "no",
    "height": "SMALL",
    "alignment": "START",
    "opponentAlignment": "END",
    "isHorizontalAllowed": true,
    "displayedTitle": "Action Pool",

    "cardActionShortcut": {
      "action": "MOVE",
      "actionData": {
        "destination": "Action_Deck"
      },
      "image": "https://merkier.github.io/MMA-Fighter-TCG/Images/icons/spend-action.png"
    }
  },

  "Action_Control": {
    "title": "Action_Control",
    "isHidden": "no",
    "height": "SMALL",
    "alignment": "CENTER",
    "isHorizontalAllowed": true,
    "displayedTitle": "Controls",
    "noQuickActions": true
  },

  "Action_Trash": {
    "title": "Action_Trash",
    "isHidden": "yes",
    "height": "SMALL",
    "alignment": "NONE",
    "isHorizontalAllowed": false,
    "displayedTitle": "Removed"
  }
}
      }
    }
  },
  "defaultRessources": {
    "backgrounds": [
      "https://merkier.github.io/MMA-Fighter-TCG/Images/playmats/01-mat.png",
      "https://merkier.github.io/MMA-Fighter-TCG/Images/playmats/02-mat.png"
    ],
    "decksUrl": "https://merkier.github.io/MMA-Fighter-TCG/MMADecks.json"
  },
  "customHelp": "Manual-play MMA card game.\n\nPRIORITY FLOW (no automation):\n• When you gain PRIORITY: restore ceil(10% of current Stamina), draw 1 Technique, then move up to 3 Action cards from Action Deck → Action Pool.\n• Actions: spend Action cards from Action Pool to pay Action costs; move them into Action Deck (recycle).\n• Range: use draggable tokens (Stand/Clinch/Ground) to track the current range.\n• Debuffs: use draggable tokens (Blurred, Limp, Cut Brow, Grip Damage, Pinned, Choked).\n\nHOW TO PLAY A CARD:\n1) Click a Technique in hand to move it to the Exchange (Stack).\n2) Opponent responds by playing a Response (or passing).\n3) Resolve manually, then click Technique cards in the Exchange to send them to Discard.\n\nTIP: The Action Pool section has a quick shortcut icon that moves a selected Action card to Action Deck (spend).",
  "cards": {
    "dataUrl": "https://merkier.github.io/MMA-Fighter-TCG/MMACards.json",
    "cardBack": "https://merkier.github.io/MMA-Fighter-TCG/Images/card-backs/technique-back.png",
    "cardBackColor": "#202020",
    "extraCardBacks": {
      "Fighter": "https://merkier.github.io/MMA-Fighter-TCG/Images/card-backs/fighter-back.png",
      "Action": "https://merkier.github.io/MMA-Fighter-TCG/Images/card-backs/action-back.png"
    }
  }
